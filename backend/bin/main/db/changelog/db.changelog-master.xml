<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="001-create-validation-history-table" author="developer">
        <createTable tableName="validation_history">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="id_number" type="VARCHAR(13)">
                <constraints nullable="false"/>
            </column>
            <column name="is_valid" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="validation_message" type="TEXT"/>
            <column name="date_of_birth" type="DATE"/>
            <column name="age" type="INTEGER"/>
            <column name="gender" type="VARCHAR(20)"/>
            <column name="citizenship_status" type="VARCHAR(30)"/>
            <column name="is_south_african_citizen" type="BOOLEAN"/>
            <column name="zodiac_sign" type="VARCHAR(20)"/>
            <column name="generation" type="VARCHAR(30)"/>
            <column name="is_adult" type="BOOLEAN"/>
            <column name="is_senior_citizen" type="BOOLEAN"/>
            <column name="client_ip" type="VARCHAR(45)"/>
            <column name="user_agent" type="TEXT"/>
            <column name="validation_timestamp" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="processing_time_ms" type="BIGINT"/>
        </createTable>
        
        <createIndex tableName="validation_history" indexName="idx_id_number">
            <column name="id_number"/>
        </createIndex>
        
        <createIndex tableName="validation_history" indexName="idx_validation_timestamp">
            <column name="validation_timestamp"/>
        </createIndex>
        
        <createIndex tableName="validation_history" indexName="idx_is_valid">
            <column name="is_valid"/>
        </createIndex>
        
        <createIndex tableName="validation_history" indexName="idx_client_ip">
            <column name="client_ip"/>
        </createIndex>
    </changeSet>

    <changeSet id="002-create-users-table" author="developer">
        <createTable tableName="users">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="VARCHAR(50)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(100)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(50)"/>
            <column name="last_name" type="VARCHAR(50)"/>
            <column name="role" type="VARCHAR(20)" defaultValue="USER">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="BOOLEAN" valueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_login" type="TIMESTAMP"/>
        </createTable>
        
        <createIndex tableName="users" indexName="idx_username">
            <column name="username"/>
        </createIndex>
        
        <createIndex tableName="users" indexName="idx_email">
            <column name="email"/>
        </createIndex>
    </changeSet>

    <changeSet id="003-insert-default-admin-user" author="developer">
        <insert tableName="users">
            <column name="username" value="admin"/>
            <column name="email" value="admin@idvalidator.com"/>
            <column name="password" value="$2a$10$EblZqNtxYUbLljz9xpc1s.OvVHVb4bCHaQDF7Jm6DQ1QJ2QrQdQjW"/>
            <column name="first_name" value="System"/>
            <column name="last_name" value="Administrator"/>
            <column name="role" value="ADMIN"/>
            <column name="enabled" valueBoolean="true"/>
        </insert>
    </changeSet>

</databaseChangeLog>
