{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && ./gradlew build -x test",
    "watchPatterns": ["backend/src/**", "frontend/src/**"]
  },
  "deploy": {
    "startCommand": "cd backend && java -jar build/libs/*.jar",
    "healthcheckPath": "/api/id-validation/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
