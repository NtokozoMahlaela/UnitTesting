{
  "version": 2,
  "name": "sa-id-validator",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "framework": "vite",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://sa-id-validator.vercel.app/api"
  }
}
